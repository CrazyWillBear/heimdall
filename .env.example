# Heimdall service configuration. Copy to `.env` and fill in. NEVER commit `.env`.
#
# docker-compose reads this file for every service. The GitHub App private key is NOT set
# here (a multiline PEM can't live in an env_file) — it is mounted as a compose secret
# from ./secrets/github_app_private_key.pem and loaded by deploy/docker-entrypoint.sh.

# --- Required -------------------------------------------------------------------------

# HMAC secret GitHub signs webhooks with (X-Hub-Signature-256). The GitHub App manifest
# flow generates one for you (the `webhook_secret` field of the conversion response).
WEBHOOK_SECRET=

# GitHub App numeric ID (the `id` field of the manifest conversion response).
GITHUB_APP_ID=

# The `claude` CLI authenticates with this. Required for any lens to run.
ANTHROPIC_API_KEY=

# Public DNS name Caddy serves TLS for (e.g. heimdall.example.com). Must resolve to this
# host with ports 80/443 open. Not needed for the localhost replay-only dogfood path.
DOMAIN=

# The PEM private key is provided as a file, not an env var. Write the App's private key
# (the `pem` field of the conversion response) to ./secrets/github_app_private_key.pem.
# Override the in-container path only if you mount it elsewhere.
# GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/github_app_private_key

# --- Optional (sane defaults; docker-compose already sets REDIS_URL/DATABASE_URL) -----

# REDIS_URL=redis://redis:6379
# DATABASE_URL=sqlite+aiosqlite:////data/heimdall.db
# CLAUDE_BINARY=claude
# BWRAP_BINARY=bwrap
# CLAUDE_ENV_PASSTHROUGH=["HTTPS_PROXY","NODE_EXTRA_CA_CERTS"]
# SANDBOX_EXTRA_READ_ONLY_BINDS=[]
# LENS_TOKEN_CAP=400000
# LENS_TIMEOUT_SECONDS=1800
# REVIEW_TIMEOUT_SECONDS=2400
# DEBUG_LOGGING=false

# --- OAuth refresher sidecar (only with `docker compose --profile oauth`) --------------
# Read by the opt-in claude-refresher service to keep subscription (OAuth) credentials
# warm; ignored in the default API-key deployment. See README "Docker deployment" → OAuth
# for the one-time credential seed. Defaults shown.
# CLAUDE_REFRESH_MODEL=haiku
# CLAUDE_REFRESH_INTERVAL_SECONDS=1800
